# AWS credentials — configure via AWS CLI or environment
AWS_REGION=us-east-1

# Bedrock model IDs
EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
LLM_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# LLM generation settings
TEMPERATURE=0.3
MAX_TOKENS=700

# Bedrock Guardrail — create via guardrails/setup_guardrail.py
GUARDRAIL_ID=your-guardrail-id-here
GUARDRAIL_VERSION=1

# Optional: ChromaDB path (defaults to ./chroma_db)
# CHROMA_DIR=./chroma_db
